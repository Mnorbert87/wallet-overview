# DEV-ONLY kulcsok (MVP). Publikálás ELŐTT vékony proxy mögé → a kulcs SOHA a
# frontend bundle-be. A VITE_ prefix miatt ezek most a kliensbe kerülnek — csak
# helyi demóhoz. Lásd README "Publikálás előtt".

# Etherscan V2 (egy kulcs minden EVM láncra) — ingyenes: https://etherscan.io/apis
VITE_ETHERSCAN_KEY=

# CoinGecko Demo (opcionális; kulcs nélkül is megy a public demo, csak lassabb rate)
# https://www.coingecko.com/en/api/pricing
VITE_COINGECKO_KEY=

# Solana RPC — a publikus api.mainnet-beta.solana.com böngésző-originből 403-at ad,
# ezért az élő SOL-egyenleghez saját RPC kell. Add meg EGYIKET:
#  - VITE_HELIUS_KEY: ingyenes Helius-kulcs (https://helius.dev) → auto mainnet.helius-rpc.com
#  - VITE_SOLANA_RPC: tetszőleges teljes RPC-URL (pl. QuickNode/Triton)
# FONTOS: dedikált (NEM a trading-botok) kulcsot használj, és publikus deploy előtt
# proxy mögé — a VITE_ prefix miatt a kulcs a kliens-bundle-be kerülne (kiszivárogna).
VITE_HELIUS_KEY=
VITE_SOLANA_RPC=
